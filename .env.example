# --- Docker Hub ---
# Пространство имён образов на Docker Hub (например, ваш логин или организация).
DOCKER_NAMESPACE=furnica
IMAGE_TAG=latest

# --- PostgreSQL ---
POSTGRES_USER=furnica
POSTGRES_PASSWORD=furnica_dev_change_me
POSTGRES_DB=furnica
POSTGRES_PORT=5432

# DSN для сервисов (внутри compose хост = postgres)
DATABASE_URL=postgres://furnica:furnica_dev_change_me@postgres:5432/furnica?sslmode=disable

# --- Kratos ---
KRATOS_PUBLIC_URL=http://localhost:4433
KRATOS_ADMIN_URL=http://kratos:4434
KRATOS_DSN=postgres://furnica:furnica_dev_change_me@postgres:5432/furnica?sslmode=disable&search_path=kratos

# --- Gateway ---
GATEWAY_PORT=8080

# --- gRPC внутренние адреса ---
CATALOG_GRPC_ADDR=catalog:9091
PRICING_GRPC_ADDR=pricing:9092
IMPORT_GRPC_ADDR=import:9093

# --- Web (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_KRATOS_PUBLIC_URL=http://localhost:4433
NEXT_PUBLIC_API_URL=http://localhost:8080
