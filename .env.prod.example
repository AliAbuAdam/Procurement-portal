# Шаблон продакшен-переменных. Скопируйте в .env.prod и заполните.
# .env.prod в .gitignore — НЕ коммитить (в нём секреты).
#
#   cp .env.prod.example .env.prod
#   # затем отредактировать значения ниже

# --- Домен и TLS ---
# Домен должен A-записью указывать на публичный IP VDS (нужно для Let's Encrypt).
DOMAIN=furnica.example.ru
ACME_EMAIL=you@example.ru

# --- Docker Hub (откуда тянуть образы) ---
DOCKER_NAMESPACE=your_dockerhub_login
IMAGE_TAG=latest

# --- PostgreSQL ---
POSTGRES_USER=furnica
# Сгенерировать: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=furnica

# DSN сервисов и Kratos (хост = postgres внутри сети compose).
# ВАЖНО: подставьте тот же пароль, что и POSTGRES_PASSWORD.
DATABASE_URL=postgres://furnica:CHANGE_ME_strong_db_password@postgres:5432/furnica?sslmode=disable
KRATOS_DSN=postgres://furnica:CHANGE_ME_strong_db_password@postgres:5432/furnica?sslmode=disable&search_path=kratos

# --- Секреты Kratos ---
# cookie: любая строка >= 32 символов. Сгенерировать: openssl rand -hex 32
KRATOS_COOKIE_SECRET=CHANGE_ME_cookie_secret_min_32_chars
# cipher: РОВНО 32 байта (AES-256). Сгенерировать: openssl rand -hex 16
KRATOS_CIPHER_SECRET=CHANGE_ME_cipher_secret_32_bytes
